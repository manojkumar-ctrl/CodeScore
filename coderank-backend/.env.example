# ============================================================
# TEMPLATE — safe to commit to Git
# Copy this file to .env, fill in real values, never commit .env
# ============================================================

DB_URL=jdbc:postgresql://<supabase-host>:6543/postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=your_supabase_password

# Generate with: openssl rand -hex 64
JWT_SECRET=your_jwt_secret_at_least_256_bits

# CORS — comma-separated allowed origins
# For production: ALLOWED_ORIGINS=https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# External API URLs (defaults are fine, override only if needed)
# GITHUB_API_URL=https://api.github.com
# LEETCODE_API_URL=https://leetcode.com
# CODEFORCES_API_URL=https://codeforces.com/api

# Redis — use 'localhost' for local dev, 'redis' when running via Docker Compose
REDIS_HOST=localhost
REDIS_PORT=6379
